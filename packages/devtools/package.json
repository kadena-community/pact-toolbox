{
  "name": "@pact-toolbox/devtools",
  "version": "0.0.1",
  "description": "Developer tools UI for the Pact Toolbox",
  "repository": "kadena-community/pact-toolbox",
  "author": "Salama Ashoush <salamaashoush@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint --import-plugin --deny-warnings",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "prepack": "pnpm run build",
    "release": "pnpm test && pnpm publish",
    "test:watch": "vitest run",
    "test": "vitest run",
    "verify": "tsc --noEmit --skipLibCheck"
  },
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "browser": {},
  "exports": {
    "solid": {
      "development": "./build/index.js",
      "import": "./build/index.js"
    },
    "development": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/dev.js"
      },
      "require": "./build/dev.cjs"
    },
    "import": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "require": "./build/index.cjs"
  },
  "files": [
    "build",
    "src",
    "!src/__tests__"
  ],
  "devDependencies": {
    "@kobalte/core": "^0.13.7",
    "@pact-toolbox/prettier-config": "workspace:*",
    "@pact-toolbox/tsconfig": "workspace:*",
    "@solid-primitives/keyed": "^1.5.0",
    "@solid-primitives/resize-observer": "^2.1.0",
    "@solid-primitives/storage": "^4.3.1",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/query-core": "^5.64.2",
    "clsx": "^2.1.1",
    "goober": "^2.1.16",
    "oxlint": "^0.15.7",
    "solid-js": "^1.9.4",
    "solid-transition-group": "^0.2.3",
    "superjson": "^2.2.2",
    "tsup": "^8.3.5",
    "tsup-preset-solid": "^2.2.0",
    "vite": "^6.0.11",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.4"
  }
}
