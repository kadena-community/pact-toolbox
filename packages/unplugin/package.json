{
  "name": "@pact-toolbox/unplugin",
  "version": "0.0.10",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kadena-community/pact-toolbox.git"
  },
  "homepage": "https://github.com/kadena-community/pact-toolbox#readme",
  "bugs": {
    "url": "https://github.com/kadena-community/pact-toolbox/issues"
  },
  "author": "Salama Ashoush <salamaashoush@gmail.com>",
  "license": "MIT",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "transform",
    "esbuild",
    "pact-lang",
    "kadena"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js",
      "require": "./dist/astro.cjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.js",
      "require": "./dist/rspack.cjs"
    },
    "./rsbuild": {
      "types": "./dist/rsbuild.d.ts",
      "import": "./dist/rsbuild.js",
      "require": "./dist/rsbuild.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js",
      "require": "./dist/webpack.cjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js",
      "require": "./dist/rollup.cjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js",
      "require": "./dist/esbuild.cjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js",
      "require": "./dist/loader.cjs"
    },
    "./*": "./*"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch src",
    "lint": "oxlint --import-plugin --deny-warnings",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "prepack": "pnpm run build",
    "release": "pnpm test && pnpm publish",
    "test:watch": "vitest",
    "test": "vitest run",
    "verify": "tsc --noEmit --skipLibCheck",
    "build:fix": "tsx scripts/postbuild.ts"
  },
  "dependencies": {
    "@pact-toolbox/config": "workspace:*",
    "@pact-toolbox/network": "workspace:*",
    "@pact-toolbox/runtime": "workspace:*",
    "@pact-toolbox/utils": "workspace:*",
    "defu": "^6.1.4",
    "picomatch": "^4.0.2",
    "scule": "^1.3.0",
    "tiny-readdir-glob": "^1.22.24",
    "tree-sitter": "^0.22.4",
    "tree-sitter-pact": "^0.0.9",
    "unplugin": "^2.1.2"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3",
    "@nuxt/schema": "^3",
    "@rsbuild/core": "^1",
    "@rspack/core": "^1",
    "esbuild": "*",
    "next": "^12",
    "rollup": "^4",
    "vite": "^5",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "webpack": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    },
    "@nuxt/schema": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "@rsbuild/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kadena/pactjs-generator": "^1.16.0",
    "@nuxt/kit": "^3.15.2",
    "@nuxt/schema": "^3.15.2",
    "@pact-toolbox/prettier-config": "workspace:*",
    "@pact-toolbox/tsconfig": "workspace:*",
    "@rsbuild/core": "^1.2.2",
    "@rspack/core": "^1.2.2",
    "@types/node": "^22.10.10",
    "@vitest/coverage-v8": "^3.0.4",
    "fast-glob": "^3.3.3",
    "next": "15.1.6",
    "oxlint": "^0.15.7",
    "prettier": "^3.4.2",
    "rollup": "^4.31.0",
    "tinybench": "^3.1.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.4",
    "webpack": "^5.97.1"
  },
  "prettier": "@pact-toolbox/prettier-config"
}
